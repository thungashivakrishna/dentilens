# Supabase Configuration Example
# Copy this file to .env and fill in your details.
# Do NOT commit your actual .env file to version control.

# The Supabase Project URL
EXPO_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co

# The Supabase Anon/Publishable Key
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-publishable-key-here

# VPS Deployment Configuration Example
VPS_HOST=your-vps-ip-here
VPS_USER=root
VPS_PASS=your-vps-password-here

